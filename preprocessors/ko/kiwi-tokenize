#!/usr/bin/env -S uv run --script
# /// script
# dependencies = ["kiwipiepy"]
# ///
# Korean morphological tokenizer using kiwipiepy.
# Protocol: reads lines from stdin, writes one tokenized line per input line to stdout.
# Outputs content morphemes only (nouns, verbs, adverbs, foreign words, numbers).
# Filters particles (J*), endings (E*), and symbols — these destroy AND query precision.
import sys
from kiwipiepy import Kiwi

kiwi = Kiwi()

def is_content(tag: str) -> bool:
    return not (tag.startswith('J') or tag.startswith('E') or
                tag in ('XPN', 'XSN', 'XSV', 'XSA',
                        'SF', 'SP', 'SS', 'SE', 'SO', 'SB', 'SW'))

for line in sys.stdin:
    line = line.rstrip('\n')
    if not line:
        print()
        sys.stdout.flush()
        continue
    try:
        tokens = kiwi.tokenize(line)
        print(' '.join(t.form for t in tokens if is_content(str(t.tag))))
    except Exception:
        print(line)
    sys.stdout.flush()
