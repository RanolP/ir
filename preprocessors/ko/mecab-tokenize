#!/usr/bin/env -S uv run --script
# /// script
# dependencies = ["python-mecab-ko"]
# ///
# Korean morphological tokenizer using MeCab (CRF-based, ~100x faster than kiwi).
# Protocol: reads lines from stdin, writes one tokenized line per input line to stdout.
# Outputs content morphemes only — filters particles (J*), endings (E*), symbols.
import sys
from mecab import MeCab

mecab = MeCab()

def is_content(tag: str) -> bool:
    return not (tag.startswith('J') or tag.startswith('E') or
                tag in ('XPN', 'XSN', 'XSV', 'XSA',
                        'SF', 'SP', 'SS', 'SE', 'SO', 'SB', 'SW', 'SWK'))

for line in sys.stdin:
    line = line.rstrip('\n')
    if not line:
        print()
        sys.stdout.flush()
        continue
    try:
        tokens = mecab.pos(line)
        print(' '.join(form for form, tag in tokens if is_content(tag)))
    except Exception:
        print(line)
    sys.stdout.flush()
